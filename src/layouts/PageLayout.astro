---
import BaseLayout from './BaseLayout.astro';
import articles from "../assets/travel-1.jpg";
import envoyage from "../assets/mongolia-2.jpg";
import envadrouille from "../assets/nz-1.jpg";
import enrando from "../assets/sancy-7.jpg";
import { Image } from 'astro:assets';
import Header from '@components/Header.astro';
import Title from '@components/Title.astro';

const { page, title } = Astro.props;
const cover = title === "EnVoyage" ? envoyage : title === "1AnEnVadrouille" ? envadrouille : title === "EnRando" ? enrando : articles;
---

<BaseLayout page={page}>
    <main>
        <Header />
        <div class="hero">
            <Title title={title}/>
            {title === "articles" ? "" : <a href="/articles"><i class="arrow" data-astro-cid-tljqxsdm="">←</i> Toutes les aventures</a>}
            <Image src={cover} alt="Roy's Peak" width="1856px" height="857px"/>
        </div>
        <div class="content">
            <slot />
        </div>
    </main>
</BaseLayout>

<style>
main {
    position: relative;
    width: 100%;
    height: 100vH;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-end;
}
