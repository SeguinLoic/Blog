} */
.hero {
    position: relative;
    width: 100%;
    display: flex;
    justify-content: flex-start;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    background-color: #000;
    background-image: url(/map.svg);
    background-size: 95%;
    padding: 0px 16vW;
    padding-top: 225px;
    padding-bottom: 80px;
    background-position: -400%;
    background-repeat: no-repeat;
}
.hero:before {
    content: "";
    width: 100%;
    height: 100%;
    position: absolute;
    left: 0;
    top: 0;
    background: linear-gradient(to right, rgb(0 0 0 / 70%), rgb(0 0 0 / 90%) 20%, #000 30%, #000000f0 38%, #0000 80%);
    z-index: 1;
}
.hero a {
    color: #fff !important;
    position: relative;
    z-index: 1;
    text-decoration: none;
}
.hero a:hover {
    text-decoration: underline !important;
}
.hero img {
    object-fit: cover;
    width: 70%;
    height: 100%;
    object-position: 0% 58%;
    position: absolute;
    right: 0;
    top: 0;
}
.content {
    width: 100%;
    padding: 60px 16vW;
}
@media screen and (max-width: 1500px) {
    .hero {
        padding: 0px 7vW;
        padding-top: 200px;
        padding-bottom: 60px;
    }
    .content {
        width: 100%;
        padding: 60px 7vW;
    }
}
@media screen and (max-width:1024px) {
    .hero {
        padding: 0px 5vW;
        padding-top: 150px;
        padding-bottom: 40px;
    }
    .content {
        padding: 40px 5vW;
    }
}
@media screen and (max-width: 600px) {
    .hero {
        flex-direction: column;
        padding-top: 80px;
        padding-bottom: 40px;
        background-size: 300%;
    }
    .hero:before {
        background: rgb(0 0 0 / 70%);
    }
    .hero img {
        display: none;
    }
}
</style>