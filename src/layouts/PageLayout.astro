.hero {
    position: relative;
    top: 0;
    left: 0;
    width: 100%;
    height: auto;
    display: flex;
    justify-content: flex-start;
    background-color: #000;
    background-image: url(/map.svg);
    background-size: cover;
    padding: 0px 16vW;
    padding-top: 200px;
    padding-bottom: 60px;
}
.hero:before {
    content: "";
    width: 100%;
    height: 100%;
    position: absolute;
    left: 0;
    top: 0;
    background: linear-gradient(to right, #000c, #000000e6 20%, #000 30%, #000000f0 38%, #0000 80%);
    z-index: 1;
}
.hero img {
    object-fit: cover;
    width: 70%;
    height: 100%;
    object-position: 0% 58%;
    position: absolute;
    right: 0;
    top: 0;
}

.content {
    width: 100%;
    padding: 60px 16vW;
}

@media screen and (max-width: 1500px) {
    .hero {
        padding: 0px 7vW;
        padding-top: 200px;
        padding-bottom: 60px;
    }
    .content {
        width: 100%;
        padding: 60px 7vW;
    }
}
@media screen and (max-width:1024px) {
    .hero {
        padding: 0px 3vW;
        padding-top: 150px;
        padding-bottom: 40px;
    }
    .content {
        padding: 40px 3vW;
    }
}
</style>