---
import BaseLayout from './BaseLayout.astro';
import cover from "../assets/nz-1.jpg";
import { Image } from 'astro:assets';
import Header from '@components/Header.astro';

const { page } = Astro.props;
---

<BaseLayout page={page}>
    <main>
        <Header />
        <div class="image">
            <Image src={cover} alt="Roy's Peak" width="1856px" height="857px"/>
            <span></span>
        </div>
        <div class="content">
            <slot />
        </div>
    </main>
</BaseLayout>

<style>
main {
    position: relative;
    width: 100%;
    height: 100vH;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-end;
}
