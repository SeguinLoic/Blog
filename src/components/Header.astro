<header>
    <a href="/" class="logo">OneHuman</a>
</header>

<style>
header {
    position: Fixed;
    top: 0;
    left: 0;
    width: 100%;
    padding: 40px;
    z-index: 1;
}
header a {
    text-decoration: none;
    color: var(--color-bg) !important;
    font-weight: 700;
    font-size: 1.4em;
}
@media screen and (max-width: 1024px) {
    header {
        position: absolute;
    }
}
@media screen and (max-width: 768px) {
    header {
        padding: 18px;
        text-align: center;
    }
    html:not(#new-home) header {
        position: relative
    }
}
@media screen and (max-width: 600px) {
    header a {
        font-size: 1.1em;
    }
}
</style>