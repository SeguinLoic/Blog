---
const { tags } = Astro.props;
---

<ul class="tags">
    {tags.map((tag) => (
        <li><a href={`/${tag}`}>#{tag}</a></li>
    ))}
</ul>

<style>
.tags {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 8px;
    list-style: none;
    min-width: 220px;
    padding: 0px;
}
.tags li a {
    font-size: .85em;
    line-height: 1.4em;
    display: flex;
    align-items: center;
    color: #2d2d2d !important;
    font-weight: 500;
    text-decoration: none;
    padding: 4px 6px;
    border: 1px solid #c3c3c3;
    transition: all 0.3s;
}
.tags li a:hover {
    border-color: #7b7b7b;
}
@media screen and (max-width: 1200px) {
    .tags {
        min-width: 160px;
        flex-direction: column;
    }
}
@media screen and (max-width: 1024px) {
    ul.tags {
        flex-direction: row;
        flex-wrap: wrap;
        width: auto;
    }
}
</style>