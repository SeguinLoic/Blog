---
import { Image } from 'astro:assets';

const {url, title, desc, date, tags, image, imageAlt} = Astro.props;
const allTags = tags.toString().split(",");
---

<article>
    <div class="imgPost">
        <Image src={image} alt={imageAlt} width="220px" height="160px" />
    </div>
    <section> 
        <div class="content">
            <h2>{title}</h2>
            <div>
                <p>{desc}</p>
                <time datetime={date}>{new Date(date).toLocaleDateString("fr-FR", { year: 'numeric', month: 'short', day: 'numeric' })}</time>
            </div>
        </div>
        <div class="tags">
            <p>Les tags</p>
            <ul>
                {allTags.map((tag) => <li><a href={`/${tag}`}>#{tag}</a></li>)}
            </ul>
        </div>
    </section>
    <a class="link" href={url}></a>
</article>

<style>
article {
    display: flex;
    position: relative;
    width: 100%;
    padding: 24px 0px;
    position: relative;
    color: #000;
}
article section {
    width: 100%;
    display: flex;
    padding: 0px 20px;
}
article h2 {
    font-weight: 500;
    font-size: clamp(1.875rem, 1.85rem + 0.125vw, 2rem);
    line-height: 1.2em;
    text-wrap: pretty;
}
article time {
    font-size: .85em;
    padding-right: 8px;
}
article ul {
    padding: 0px;
    display: flex;
    list-style: none;
    position: relative;
    z-index: 2;
    flex-direction: column;
}
article ul li {
    padding: 5px 0px;
}
article ul li a {
    font-size: 0.9em;
    line-height: 1em;
    display: flex;
    align-items: center;
    color: #b38c40 !important;
    font-weight: 700;
    text-decoration: none;
}
article p {
    line-height: 1.4;
}
article img {
    object-fit: cover;
    overflow-clip-margin: unset;
}
a.link {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    background-color: var(--color-fg);
    opacity: 0;
    transition: all 0.3s;
}
@media screen and (max-width: 768px) {
    article {
        padding: 24px 0px;
        flex-direction: column;
    }   
    article img {
        width: 100%;
        min-width: 100%;
    }
    article section {
        padding-right: 0px;
        padding-left: 0px;
        padding-top: 16px;
        flex-direction: column;
        gap: 12px
    }
    article section .content {
        width: 100%;
    }
    article section .content div {
        padding-top: 12px;
    }
}
@media screen and (max-width: 500px) {
    article time {
        width: 100%;
        font-size: 0.8em;
    }
    article p {
        display: none;
    }
    article ul {
        padding-left: 0px;
    }
    article ul:before {
        display: none;
    }
    article ul li a {
        font-size: 0.9em;
        font-weight: 500;
    }
    article img {
        width: 80px;
        height: 80px;
    }
}
</style>