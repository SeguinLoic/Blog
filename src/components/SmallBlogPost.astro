---
import { Image } from 'astro:assets';

const {url, title, date, image, imageAlt} = Astro.props;
---

<article>
    <div class="image">
        <a href={url}>
            <Image src={image} alt={imageAlt} layout='constrained' width="800px" height="600px" />
        </a>
    </div>
    <div class="content"> 
        <a href={url}>
            <h3>{title}</h3>
            <span>Publié le <time datetime={date}>{new Date(date).toLocaleDateString("fr-FR", { year: 'numeric', month: 'short', day: 'numeric' })}</time></span>
        </a>
    </section>
</article>

<style>
article {
    display: flex;
    width: 100%;
    position: relative;
    gap: 24px;
}
article:not(:last-child) {
    margin-bottom: 24px;
}
article .content a {
    display: flex;
    height: 100%;
    flex-direction: column;
    gap: 8px;
    text-decoration: none;
    color: #fff;
}
.content h3 {
    font-weight: 500;
    font-size: clamp(1.125rem, 1.1rem + 0.125vw, 1.25rem);
    line-height: 1.2em;
    text-wrap: pretty;
    color: #fff;
}
.content a:hover h3,
.content a:hover span {
    text-decoration: underline;
}
.content time {
    font-size: .85em;
    color: #fff;
}
.image,
.image a {
    display: flex;
}
.image a {
    overflow: hidden;
}
.image img {
    width: 140px;
    height: 90px;
    object-fit: cover;
    overflow-clip-margin: unset;
    transition: all 0.3s;
}
.image a:hover img {
    transform: scale(1.05);
}
@media screen and (max-width: 1200px) {
    article {
        gap: 32px;
    }
}
@media screen and (max-width: 1024px) {
    .image img {
        width: 220px;
        height: 150px;
    }
}
@media screen and (max-width: 768px) {
    article {
        flex-direction: column;
        gap: 16px;
    }   
    .image, 
    .image a {
        width: 100%;
    }
    .image {
        height: 300px;
    }
    .image img {
        width: 100%;
        min-width: 100%;
        height: 100%
    }
}
@media screen and (max-width: 500px) {
    .content time {
        font-size: 0.8em;
    }
    .image {
        height: 200px;
    }
}
</style>