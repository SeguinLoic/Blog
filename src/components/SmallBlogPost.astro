---
import { Image } from 'astro:assets';

const {url, title, date, image, imageAlt} = Astro.props;
---

<article>
    <div class="image">
        <a href={url}>
            <Image src={image} alt={imageAlt} layout='constrained' width="800px" height="600px" />
        </a>
    </div>
    <div class="content"> 
        <a href={url}>
            <div class="title">
                <h2>{title}</h2>
                <span>Publié le <time datetime={date}>{new Date(date).toLocaleDateString("fr-FR", { year: 'numeric', month: 'short', day: 'numeric' })}</time></span>
            </div>
        </a>
    </section>
</article>

<style>
article {
    display: flex;
    width: 100%;
    margin-bottom: 32px;
    padding-bottom: 32px;
    position: relative;
    color: #000;
    gap: 40px;
}
article:after {
    content: '';
    width: 100%;
    height: 1px;
    background-color: #000;
    position: absolute;
    bottom: 0;
    left: 0;
    opacity: 0.1;
    pointer-events: none;
}
section>div a:hover .title h2 {
    text-decoration: underline;
}
.title {
    display: flex;
    flex-direction: column;
    gap: 8px;
}
.title time {
    font-size: .85em;
}
.title h2 {
    font-weight: 500;
    font-size: clamp(1.375rem, 1.35rem + 0.125vw, 1.5rem);
    line-height: 1.2em;
    text-wrap: pretty;
    color: #000;
}
.image,
.image a {
    display: flex;
}
.image a {
    overflow: hidden;
}
.image img {
    width: 160px;
    height: 110px;
    object-fit: cover;
    overflow-clip-margin: unset;
    transition: all 0.3s;
}
.image a:hover img {
    transform: scale(1.05);
}
@media screen and (max-width: 1200px) {
    article {
        gap: 32px;
    }
}
@media screen and (max-width: 1024px) {
    .image img {
        width: 220px;
        height: 150px;
    }
    .title {
        order: 2;
    }
}
@media screen and (max-width: 768px) {
    article {
        flex-direction: column;
        gap: 16px;
    }   
    .image, 
    .image a {
        width: 100%;
    }
    .image {
        height: 300px;
    }
    .image img {
        width: 100%;
        min-width: 100%;
        height: 100%
    }
}
@media screen and (max-width: 500px) {
    .title time {
        font-size: 0.8em;
    }
    .image {
        height: 200px;
    }
}
</style>