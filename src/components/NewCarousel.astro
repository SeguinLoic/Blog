<style>
.carousel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}
.carousel-inner {
    display: flex;
}
/* .slide {
    height: 100%;
    transition: .5s ease-in-out;
    opacity: 0;
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
} 
.slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}*/
.slide {
    height: 100%;
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
}
.slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: .5s ease-in-out;
    opacity: 0;
    pointer-events: none;
}
.slide.active img {
    opacity: 1;
    pointer-events: auto;
}
/* .carousel-controls {
    position: absolute;
    z-index: 5;
    right: 0;
    top: 50%;
    display: flex;
    justify-content: space-between;
    transform: translateY(-50%);
} */
.carousel-controls {
    position: absolute;
    z-index: 5;
    display: flex;
    justify-content: flex-end;
    bottom: 0;
    right: 0;
    height: 200px;
    width: 33%;
    background-color: #000;
    background-image: url(/map.svg);
    background-repeat: no-repeat;
    background-size: 260%;
    background-position: 50% 43%;
}
.carousel-controls:after {
    content: "";
    width: 100%;
    height: 100%;
    background: linear-gradient(to left, rgb(0 0 0) 10%, rgb(0 0 0 / 72%) 70%);
    position: absolute;
    left: 0;
    top: 0;
    z-index: -1;
}
.carousel-controls button {
    padding: 13px;
    background-color: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    width: 50px;
    height: 50px;
    transform: translateY(-100%);
}
.carousel-controls button img {
    width: 22px;
    height: 20px;
    filter: invert(1);
}
.carousel-controls button#next img {
    transform: rotate(180deg);
}
.postInfo {
    position: absolute;
    bottom: 0;
    right: 150px;
    z-index: 1;
    padding: 0px 40px;
    gap: 12px;
    display: flex;
    flex-direction: column;
    width: calc(33% - 150px);
    height: 200px;
    z-index: 6;
    transition: .5s ease-in-out;
    opacity: 0;
    pointer-events: none;
    /* transform: translateY(-20px); */
    justify-content: flex-end;
    padding-bottom: 40px;
}
.slide.active .postInfo {
    opacity: 1;
    pointer-events: auto;
    /* transform: translateY(0px); */
}
.postInfo p {
    color: #fff !important;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.5em;
}
.postInfo a {
    color: #fff !important;
}
@media screen and (max-width: 768px) {
    .carousel-controls button {
        padding: 10px;
    }
    .carousel-controls[data-astro-cid-z34dqrwr] {
        right: inherit;
        top: initial;
        transform: translateY(-50%);
        bottom: 0;
        left: 50%;
    }
    .postInfo,
    .carousel-controls {
        display: none;
    }
}
</style>