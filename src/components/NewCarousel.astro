---
import { Image } from 'astro:assets';

const { posts } = Astro.props; 
---
<div class="carousel">
    <div class="carousel-inner">
        {posts.map((post: any) => (
            <div class="slide">
                <div class="postInfo">
                    <p>{post.data.title}</p>
                    <a href={`/posts/${post.id}`}>Lire l'article</a>
                </div>
                <Image src={post.data.homepage} alt="image" layout="constrained" loading="lazy" width="1920px" height="1080px" />
            </div>
        ))}
    </div>
    <div class="carousel-controls">
        <button id="prev"><img src="/icon-arrow.svg"/></button>
        <button id="next"><img src="/icon-arrow.svg"/></button>
    </div>
</div>

<script>

(function () {
    "use stict"
    // const slideTimeout = 4000;
    const prev = document.querySelector('#prev');
    const next = document.querySelector('#next');
    const $slides = document.querySelectorAll('.slide');
    let intervalId;
    let currentSlide = 0;
    $slides[currentSlide].classList.add("active");

    function slideTo(index) {
        currentSlide = index >= $slides.length ? 0 : currentSlide = index < 0 ? ($slides.length - 1) : index;
        $slides.forEach($elt => $elt.classList.remove("active"));
        $slides[currentSlide].classList.add("active");
    }

    prev.addEventListener('click', () => slideTo(--currentSlide))
    next.addEventListener('click', () => slideTo(++currentSlide))

    // function showSlide() {
    //     slideTo(currentSlide);
    //     currentSlide++;
    // }

    // Initialisation de l'intervalle pour afficher les slides
    // intervalId = setInterval(showSlide, slideTimeout)
    
    // Boucle sur tous les éléments de type "slide" pour ajouter des écouteurs d'événement pour les interactions avec la souris et le toucher
    $slides.forEach($elt => {
        let startX;
        let endX;

        // $elt.addEventListener('mouseover', () => {
        //     clearInterval(intervalId);
        // }, false)

        // $elt.addEventListener('mouseout', () => {
        //     intervalId = setInterval(showSlide, slideTimeout);
        // }, false);

        $elt.addEventListener('touchstart', (event) => {
            startX = event.touches[0].clientX;
        });

        $elt.addEventListener('touchend', (event) => {
            endX = event.changedTouches[0].clientX;
            if (startX > endX) {
                slideTo(currentSlide + 1);
            } else if (startX < endX) {
                slideTo(currentSlide - 1);
            }
        });

    })
})()

