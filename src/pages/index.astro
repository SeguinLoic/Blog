---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import image1 from "../assets/mongolia-7.jpg"
import image2 from "../assets/mongolia-2.jpg"
import image3 from "../assets/china-10.jpg"
import NewCarousel from '@components/NewCarousel.astro';
import { getCollection } from "astro:content";

const allBlogPosts = (await getCollection('blog')).map((post: any) => post.data.homepage.src ? post : "").filter(function(elem: any) { return elem });

const page = "home";
---
<BaseLayout page={page}>
    <main>
        <Header />
        <div class="content">
            <h1>Vivre des expériences</h1>
            <p>À quelques jours du grand départ pour mon voyage d’une année en Asie, quelqu’un m’a conseillé de “Vivre des expériences”. Cette phrase m’est restée en tête jusqu’à aujourd’hui. Je trouve que c’est le meilleur conseil que l’on puisse donner à un être humain.</p>
            <a href="/articles">Partir à l'aventure</a>
        </div>
        <div class="image">
            <NewCarousel posts={allBlogPosts} />
        </div>
    </main>
</BaseLayout>

<style>
main {
    display: flex;
    flex-direction: column;
    /* justify-content: flex-end; */
    justify-content: center;
    background-color: #000;
}
.content  h1 {
    color: #fff;
    font-size: clamp(2.5rem, 2.125rem + 1.875vw, 4.375rem);
    line-height: clamp(3.125rem, 2.8125rem + 1.5625vw, 4.6875rem);
    width: 70%;
}
.content {
    z-index: 1;
    padding: 40px 60px;
    display: flex;
    flex-direction: column;
    gap: 24px;
    width: 45%;
}
.content p {
    color: #FFF !important;
    line-height: 1.7;
}
.content a {
    color: #FFF !important;
}
.image {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vW;
    height: 100vH;
}
.image img {
    object-fit: cover;
    width: 100%;
    height: 100%;
}
.image:after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, rgba(0, 0, 0, 0.5), transparent 70%);
    pointer-events: none;
}
@media screen and (max-width: 1024px) {
    .content {
        width: 80%;
    }
}
@media screen and (max-width: 768px) {
    main {
        justify-content: flex-start;
        align-items: center;
    }
    .content {
        width: 100%;
        gap: 16px;
        text-align: center;
        padding: 0 80px;
        flex-grow: 1;
        align-items: center;
        justify-content: center;
    }
    .content p {
        line-height: 1.5;
    }
    .image:after {
        background: rgba(0, 0, 0, 0.3);
    }
}
@media screen and (max-width: 600px) {
    .content {
        padding: 0px 40px;
    }
    .content h1 {
        width: 100%;
    }
}
@media screen and (max-width: 400px) {
    .content {
        padding: 0px 24px;
    }
}
</style>