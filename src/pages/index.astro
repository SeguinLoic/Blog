---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import HomeCarousel from '@components/HomeCarousel.astro';
import { getCollection } from "astro:content";

const allBlogPosts = (await getCollection('blog')).map((post: any) => post.data.homepage.src ? post : "").filter(function(elem: any) { return elem });

const page = "home";
---
<BaseLayout page={page}>
    <main>
        <Header />
        <div class="content">
            <h1>Vivre des expériences</h1>
            <a href="/articles">Partir à l'aventure →</a>
        </div>
        <div class="image">
            <HomeCarousel posts={allBlogPosts} />
        </div>
    </main>
</BaseLayout>

<style>
main {
    display: flex;
    flex-direction: column;
    justify-content: center;
    background-color: #000;
}
.content  h1 {
    color: #fff;
    font-size: clamp(2.8125rem, 2.25rem + 2.8125vw, 5.625rem);
    line-height: clamp(2.8125rem, 2.25rem + 2.8125vw, 5.625rem);
    width: 87%;
}
.content {
    z-index: 1;
    padding: 40px 60px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    width: 45%;
    align-items: flex-start;
}
.content p {
    color: #FFF !important;
    line-height: 1.7;
}
.content a {
    color: #000000;
    text-decoration: none;
    background-color: #fff;
    padding: 10px 16px;
    font-weight: 500;
    transition: all 0.3s;
}
.content a:hover {
    color: #ffffff !important;
    background-color: #000000;
    text-decoration: underline;
}
.image {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vW;
    height: 100%;
}
.image img {
    object-fit: cover;
    width: 100%;
    height: 100%;
}
.image:after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, rgba(0, 0, 0, 0.5), transparent 70%);
    pointer-events: none;
}
@media screen and (max-width: 1024px) {
    .content {
        width: 80%;
    }
}
@media screen and (max-width: 768px) {
    main {
        justify-content: flex-start;
        align-items: center;
    }
    .content {
        width: 100%;
        gap: 32px;
        text-align: center;
        padding: 0 80px;
        flex-grow: 1;
        align-items: center;
        justify-content: center;
    }
    .content p {
        display: none;
    }
    .image:after {
        background: rgba(0, 0, 0, 0.3);
    }
}
@media screen and (max-width: 600px) {
    .content {
        padding: 0px 40px;
    }
    .content h1 {
        width: 100%;
    }
}
@media screen and (max-width: 400px) {
    .content {
        padding: 0px 24px;
    }
}
</style>