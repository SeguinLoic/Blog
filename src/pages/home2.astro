---
import '../styles/newglobal.css';
import NewBaseLayout from '../layouts/NewBaseLayout.astro';
import Header from '@components/Header.astro';
import NewCarousel from '@components/NewCarousel.astro';
import Carousel from '@components/Carousel.astro';
import Footer from '@components/Footer.astro';
import { getCollection } from "astro:content";
import NewShortBlogPost from '@components/NewShortBlogPost.astro';

import image1 from "../assets/mongolia-2.jpg"
import image2 from "../assets/mongolia-6.jpg"
import image3 from "../assets/mongolia-7.jpg"

const allBlogPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const blogPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0,3);

const page = "new-home";
---

<NewBaseLayout page={page}>
    <!-- <Header /> -->
    <main>
        <!-- <div class="intro">
            <h1>Vivre des expériences</h1>
            <p>À quelques jours du grand départ pour mon voyage d’une année en Asie, quelqu’un m’a conseillé de “Vivre des expériences”. Cette phrase m’est restée en tête jusqu’à aujourd’hui. Je trouve que c’est le meilleur conseil que l’on puisse donner à un être humain.</p>
            <a href="/articles">Découvrir des aventures</a>
        </div> -->
        <div class="fenetre">
            <h1>Vivre des expériences</h1>
            <Carousel images={[image1, image2, image3]} />
            <!-- <NewCarousel articles={blogPosts} /> -->
        </div>
        <div class="desc">
            <Header />
            <p>À quelques jours du grand départ pour mon voyage d’une année en Asie, quelqu’un m’a conseillé de “Vivre des expériences”. Cette phrase m’est restée en tête jusqu’à aujourd’hui. Je trouve que c’est le meilleur conseil que l’on puisse donner à un être humain.</p>
            <!-- <h2>Les dernières expéditions</h2> -->
            <div class="articles">
                {allBlogPosts.map((post) => <NewShortBlogPost title={post.data.title} desc={post.data.description} date={post.data.pubDate} tags={post.data.tags} url={`/posts/${post.id}`} image={post.data.cover} imageAlt={post.data.coverAlt} />)}
            </div>
        </div>
    </main>
    <!-- <Footer /> -->
</NewBaseLayout>

<style>
.intro {
    width: 25%;
    padding-top: 100px;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding-right: 40px;
}
.intro h1 {
    font-size: 65px;
    line-height: 60px;
    padding-bottom: 24px;
}
.intro p {
    line-height: 1.8em;
}
/* .intro a {
    margin-top: 24px !important;
    border: 1px solid #4d4d4d;
    padding: 12px 24px;
    position: relative;
    display: flex;
    justify-content: flex-start;
    text-decoration: none;
} */
/* .fenetre {
    width: 50%;
    height: calc(100vH - 183px);
} */
.fenetre {
    width: 35%;
    height: 100vH;
    position: fixed;
    top: 0;
    left: 0;
}
.fenetre h1 {
     position: absolute;
    z-index: 1;
    bottom: 40px;
    left: 40px;
    color: #fff;
    font-size: 70px;
    line-height: 75px;
}
.fenetre img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
/* .desc {
    width: 25%;
    display: flex;
    align-items: flex-start;
    padding-left: 40px;
    flex-direction: column;
    justify-content: flex-end;
    gap: 16px;
} */
.desc {
    width: 65%;
    display: flex;
    align-items: flex-start;
    padding: 80px;
    flex-direction: column;
    gap: 16px;
    left: 35%;
    position: relative;
}
.desc p {
    line-height: 2em;
