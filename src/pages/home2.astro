/* .fenetre {
    width: calc(100vW - 64px);
    height: calc(100vH - 64px);
    position: fixed;
    top: 32px;
    left: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
} */
.fenetre {
    width: 100vW;
    height: 100vH;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.fenetre > a {
    position: absolute;
    width: 100%;
    height: 100%;
    top: 0;
    left: 0;
    z-index: 1;
}
.fenetre h1 {
     position: absolute;
    z-index: 1;
    bottom: 40px;
    left: 40px;
    color: #fff;
    font-size: 70px;
    line-height: 75px;
}
.fenetre img {
    position: absolute;
    top: 0;
    left: 0;
    object-fit: cover;
    width: 100%;
    height: 100%;
}
.fenetre:after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, rgba(0, 0, 0, 0.5), transparent 70%);
    pointer-events: none;
}
/* .desc {
    width: 25%;
    display: flex;
    align-items: flex-start;
    padding-left: 40px;
    flex-direction: column;
    justify-content: flex-end;
    gap: 16px;
} */
.desc {
    width: 70%;
    display: flex;
    align-items: flex-start;
    padding: 80px 120px;
    flex-direction: column;
    gap: 16px;
    left: 30%;
    position: relative;
}
.desc p {
    line-height: 2em;
    display: none;
}


.menu {
    display: flex;
    width: 100%;
    padding-top: 20px;
    padding-bottom: 8px;
    padding-left: 8px;
    border-bottom: 1px solid #0000002e;
}
.menu ul {
    list-style: none;
    display: flex;
    padding: 0px;
    gap: 16px;
}
.menu ul li {
    font-weight: 700;
    opacity: 0.3;
}
.menu ul li:first-child {
    opacity: 1;
}


.cursor, .inner {
    position: absolute;
}
.cursor {
    align-items: center;
    display: flex;
    height: 5.9722222222vw;
    justify-content: center;
    pointer-events: none;
    width: 5.9722222222vw;
    z-index: 20;
    top: 50%;
    left: 50%;
    opacity: 1;
    transform: scale(1);
    transition-property : opacity, transform;
    transition-duration : 0.3s;
}
.inner {
    backdrop-filter: blur(20px);
    background: rgba(0, 0, 0, .15);
    border-radius: 100%;
    bottom: 0;
    left: 0;
    overflow: hidden;
    right: 0;
    top: 0;
    color: #fff;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
}
.cursor.out {
    opacity: 0;
    transform: scale(0.8);
}

</style>