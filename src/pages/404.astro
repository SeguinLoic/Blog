---
import '../styles/global.css';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import { Image } from 'astro:assets';
import image3 from "../assets/mongolia/mongolia-10.jpg"

const page = "lost";
---

<BaseLayout page={page}>
    <main>
        <Header />
        <div class="content">
            <h1>404</h1>
            <p class="punchline">Vous venez de vous perdre dans le Désert de Gobi</p>
            <p>Retour à la <a href="/">page d'accueil</a></p>
        </div>
        <div class="image">
            <Image src={image3} alt="Mongolie" width="1856px" height="857px" />
        </div>
    </main>
</PageLayout>

<style>
main {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
}
.content  h1 {
    color: #fff;
    font-size: clamp(2.5rem, 2.125rem + 1.875vw, 4.375rem);
    line-height: clamp(3.125rem, 2.8125rem + 1.5625vw, 4.6875rem);
}
.content {
    z-index: 1;
    padding: 40px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    justify-content: center;
    text-align: center;
}
.content p {
    color: #FFF !important;
    line-height: 1.7;
}
.content a {
    color: #FFF !important;
}
.image {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vW;
    height: 100vH;
}
.image img {
    object-fit: cover;
    width: 100%;
    height: 100%;
}
.image:after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    /* background: linear-gradient(45deg, rgba(0, 0, 0, 0.5), transparent 70%); */
    background: rgb(0 0 0 / 25%);
    pointer-events: none;
}
</style>