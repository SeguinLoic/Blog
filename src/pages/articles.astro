---
import PageLayout from '../layouts/PageLayout.astro';
import ShortBlogPost from '@components/ShortBlogPost.astro';
import Tags from '@components/Tags.astro';
import { Debug } from 'astro:components';
import { getCollection } from "astro:content";


const tags = [];
const allBlogPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = (await getCollection('blog')).map((post: any) => post.data.tags).flat();
allTags.map(elem => { 
    tags.map(tag => {
        tag.name === elem ? tag.number++ : tags.push({name: elem, number: 1});
    })
});

const filteredTags = allTags.filter((item: any, index: any) => allTags.indexOf(item) === index);

const page = "articles";
---
<Debug {allTags} />
<Debug {tags} />
<PageLayout page={page} title={page}>
    <nav>
        <p>Filtrer par thématique :</p>
        <Tags tags={filteredTags} />
    </nav>
    <div class="articles">
        {allBlogPosts.map((post: any) => <ShortBlogPost title={post.data.title} desc={post.data.description} date={post.data.pubDate} tags={post.data.tags} url={`/posts/${post.id}`} image={post.data.cover} imageAlt={post.data.coverAlt} />)}
    </div>
</PageLayout>

<style>
.articles {
    display: flex;
    flex-direction: column;
    margin-top: 160px;
}
nav {
    padding: 32px 0;
    background-color: #f5f5f5;
    position: absolute;
    display: flex;
    gap: 16px;
    width: 100%;
    left: 0;
    padding: 32px 16vW;
    height: 100px;
    align-items: center;
    justify-content: flex-start;
}
@media screen and (max-width: 1500px) {
    nav {
        padding: 32px 7vW;
    }
}
@media screen and (max-width: 1024px) {
    .articles {
        margin-top: 120px;
    }
    nav {
        padding: 24px 5vW;
        height: 80px;
    }
}
@media screen and (max-width: 600px) {
    .articles {
        margin-top: 40px;
    }
    nav {
        flex-direction: column;
        align-items: flex-start;
        padding: 24px 0px;
        position: relative;
        height: auto;
        background-color: transparent;
    }
    nav:after {
        content: '';
        width: 100vW;
        height: 100%;
        background-color: #f5f5f5;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        z-index: -1;
    }
}
</style>