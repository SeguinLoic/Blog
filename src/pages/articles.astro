---
import image7 from "../assets/mongolia-7.jpg";
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import ShortBlogPost from '@components/ShortBlogPost.astro';
import { getCollection } from "astro:content";
import { Debug } from 'astro:components';

const allBlogPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = (await getCollection('blog')).map((post: any) => post.data.tags).flat().filter((item: any, index: any) => this.indexOf(item) === index);


const page = "articles";
---
<BaseLayout page={page}>
    <Debug {allTags} />
    <main>
        <Header />
        <div class="image">
            <Image src={image7} alt="Mongolie" width="1856px" height="857px"/>
        </div>
        <div class="content">
            <nav>
                <h1>Toutes les aventures</h1>
                <p>Tags : <span>#Rando</span> <span></span>#1AnEnVadrouille</span> <span></span>#Voyage</span></p>
            </nav>
            <div class="articles">
                {allBlogPosts.map((post: any) => <ShortBlogPost title={post.data.title} desc={post.data.description} date={post.data.pubDate} tags={post.data.tags} url={`/posts/${post.id}`} image={post.data.cover} imageAlt={post.data.coverAlt} />)}
            </div>
        </div>
    </main>
</BaseLayout>

<style>
main {
    width: 100%;
    position: relative;
    height: 100vH;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: flex-end;
}
.image {
    position: relative;
    top: 0;
    left: 0;
    width: 100vW;
    height: 250px;
}
.image:after {
    content: "";
    position: fixed;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(45deg, rgba(0, 0, 0, .5), transparent 70%);
    pointer-events: none;
}
.image img {
    object-fit: cover;
    width: 100%;
    height: 100%;
}
.content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 60px 0px;
    position: relative;
    background-color: #fff;
    z-index: 1;
}
nav {
    padding-bottom: 24px;
}
.articles {
    display: flex;
    flex-direction: column;
}
.articles, nav {
    width: 1200px;
}
@media screen and (max-width: 1239px) {
   .articles, nav {
        width: 100%;
    } 
    .content {
        padding: 60px 40px;
    }
}
@media screen and (max-width:1024px) {
    .image {
        height: 250px;
        position: relative;
    }
    .content {
        padding: 40px 32px;
    }
}
@media screen and (max-width: 768px) {
    .image {
        display: none;
    }
    .content {
        padding: 24px 16px;
    }
}
</style>