---
import PageLayout from '../layouts/PageLayout.astro';
import ShortBlogPost from '@components/ShortBlogPost.astro';
import Tags from '@components/Tags.astro';
import { getCollection } from "astro:content";

const allBlogPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const allTags = (await getCollection('blog')).map((post: any) => post.data.tags).flat();
const filteredTags = allTags.filter((item: any, index: any) => allTags.indexOf(item) === index)

const page = "articles";
---

<PageLayout page={page} title={page}>
    <nav>
        <p>Filtrer par thématique :</p>
        <Tags tags={filteredTags} />
    </nav>
    <div class="articles">
        {allBlogPosts.map((post: any) => <ShortBlogPost title={post.data.title} desc={post.data.description} date={post.data.pubDate} tags={post.data.tags} url={`/posts/${post.id}`} image={post.data.cover} imageAlt={post.data.coverAlt} />)}
    </div>
</PageLayout>

<style>
.articles {
    display: flex;
    flex-direction: column;
}
nav {
    margin-bottom: 60px;
    margin-top: -60px;
    padding: 32px 0px;
    background-color: #f5f5f5;
    display: flex;
    position: relative;
    display: flex;
    gap: 16px;
}
nav:after {
    content: '';
    width: 100vW;
    height: 100%;
    background-color: #f5f5f5;
    position: absolute;
    left: 50%;
    top: 0;
    transform: translateX(-50%);
    z-index: -1;
}
</style>